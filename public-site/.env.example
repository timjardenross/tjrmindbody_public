# Public site URL used for canonical links, RSS, sitemap and OG tags.
NEXT_PUBLIC_SITE_URL=https://www.tjrmindbody.com

# GitHub repo the CMS commits content into ("owner/repo").
NEXT_PUBLIC_CMS_REPO=timjardenross/USSTJROS
NEXT_PUBLIC_CMS_BRANCH=main
# Content lives under this path in the repo (see public-site/content).
NEXT_PUBLIC_CMS_BASE_PATH=public-site

# GitHub OAuth App credentials for the /admin editor (see docs/CMS-SETUP.md).
# Authorization callback URL on the OAuth App must be: <site-url>/api/auth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
